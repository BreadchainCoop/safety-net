{
  "extends": "solhint:recommended",
  "rules": {
    "explicit-types": ["warn", "explicit"],
    "reason-string": ["error", { "maxLength": 64 }],
    "visibility-modifier-order": "error",
    "no-empty-blocks": "error",
    "use-natspec": ["warn",
      {
        "title": { "enabled": true, "ignore": {} },
        "author": { "enabled": true, "ignore": {} },
        "notice": { "enabled": true, "ignore": {} },
        "param": { "enabled": true, "ignore": {} },
        "return": { "enabled": true, "ignore": {} }
      }
    ],
    "private-vars-leading-underscore": ["warn",
      {
        "strict": false
      }
    ],
    "compiler-version": ["warn"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "reentrancy": "error",
    "avoid-low-level-calls": "error",
    "avoid-call-value": "error",
    "check-send-result": "error",
    "avoid-tx-origin": "error",
    "no-inline-assembly": "error",
    "payable-fallback": "error",
    "max-states-count": "off",
    "function-max-lines": "off",
    "import-path-check": "off",
    "gas-calldata-parameters": "off",
    "gas-increment-by-one": "off",
    "gas-indexed-events": "off",
    "gas-small-strings": "off",
    "gas-strict-inequalities": "off",
    "gas-struct-packing": "off",
    "quotes": "off"
  }
}