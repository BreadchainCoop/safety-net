# SafetyNet proxy address on Gnosis (chain 100). Falls back to the canonical
# deployment in src/lib/config.ts when unset; set to zero address to disable
# on-chain calls. Malformed values fail the build (zod-validated).
NEXT_PUBLIC_SAFETYNET_ADDRESS=

# Gnosis RPC endpoint (default: https://rpc.gnosischain.com, with public
# fallbacks — see src/lib/wagmi.ts)
NEXT_PUBLIC_RPC_URL=

# WalletConnect Cloud project id (required for WalletConnect wallets;
# injected wallets work without it)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Canonical site URL for OG/Twitter link unfurls (default: the GitHub Pages
# deployment, https://breadchaincoop.github.io/safety-net)
NEXT_PUBLIC_SITE_URL=

# Optional subpath hosting (e.g. /safety-net on GitHub Pages)
NEXT_PUBLIC_BASE_PATH=

# Privy embedded wallets (optional). When set (and not in verify mode) the app
# switches from RainbowKit to Privy embedded wallets with gas sponsorship on
# Gnosis. Create the app at dashboard.privy.io (Gnosis chain, embedded wallets
# on, gas sponsorship configured there). Absent ⇒ current RainbowKit behavior.
# See the README's "Privy embedded wallets" section.
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional Privy client id (passed alongside the app id).
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Verify mode (E2E onchain testing) is dev-only and intentionally NOT listed
# here — never put key material next to production config. See
# .env.verify.example and the README's "Verify mode" section.
