# SafetyNet proxy address on Gnosis (chain 100). Placeholder zero address by
# default — set this once the contract is deployed.
NEXT_PUBLIC_SAFETYNET_ADDRESS=0x0000000000000000000000000000000000000000

# Gnosis RPC endpoint (default: https://rpc.gnosischain.com)
NEXT_PUBLIC_RPC_URL=

# WalletConnect Cloud project id (required for WalletConnect wallets;
# injected wallets work without it)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Verify mode (E2E onchain testing — NEVER enable in production) ──────────
# When both are set, a "Dev Wallet" connect option is exposed that signs and
# sends real transactions on Gnosis from the given private key, without a
# browser extension. A visible VERIFY MODE banner is shown.
NEXT_PUBLIC_VERIFY_MODE=false
NEXT_PUBLIC_VERIFY_PRIVATE_KEY=
