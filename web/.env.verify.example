# ── Verify mode (E2E onchain testing) — DEV ONLY ─────────────────────────────
# Copy to .env.verify (gitignored) and load for `next dev` runs only, e.g.:
#   env $(cat .env.verify | xargs) pnpm dev
#
# SECURITY: the key is only read when NODE_ENV=development AND
# NEXT_PUBLIC_VERIFY_MODE=true (src/lib/config.ts). Production builds strip it
# even if the env var is set. Still: use a throwaway test key with minimal
# funds, keep it out of .env, and NEVER define these in CI / Pages variables.
NEXT_PUBLIC_VERIFY_MODE=true
NEXT_PUBLIC_VERIFY_PRIVATE_KEY=0x<throwaway test key>
